+    /// Parse PT (P-touch) series settings. Added by stockr patch so we can
+    /// print to PT-P710BT over Bluetooth. The PT series uses TZe laminated
+    /// tape (labelSize enum values 0..5 cover 3.5mm..24mm widths; index 5
+    /// = BRLMPTPrintSettingsLabelSizeWidth24mm, which is what PT-P710BT
+    /// accepts when loaded with 24mm TZe tape).
+    private static func _parseSettings_PTSeries(_ reader: DictionaryReadWrite, model: BRLMPrinterModel) throws -> BRLMPTPrintSettings {
+        guard let settings = BRLMPTPrintSettings(defaultPrintSettingsWith: model) else {
+            throw GenericError(description: "Failed to initialize PT printer settings object")
+        }
+
+        settings.labelSize               = reader.read("labelSize",               nvl: settings.labelSize) { BRLMPTPrintSettingsLabelSize(rawValue: $0) }
+        settings.autoCutForEachPageCount = reader.read("autoCutForEachPageCount", nvl: 1)
+        settings.autoCut                 = reader.read("autoCut",                 nvl: true)
+        settings.halfCut                 = reader.read("halfCut",                 nvl: false)
+        settings.chainPrint              = reader.read("chainPrint",              nvl: false)
+        settings.specialTapePrint        = reader.read("specialTapePrint",        nvl: false)
+        settings.cutmarkPrint            = reader.read("cutmarkPrint",            nvl: false)
+        settings.cutPause                = reader.read("cutPause",                nvl: false)
+        settings.forceVanishingMargin    = reader.read("forceVanishingMargin",    nvl: false)
+        settings.resolution              = reader.read("resolution",              nvl: .normal) { BRLMPrintSettingsResolution(rawValue: $0) }
+
+        return settings
+    }
+
     internal static func settingsFromDictionary(_ settings: [String: Any], modelName: String) throws  -> BRLMPrintSettingsProtocol {
 
         // decode supported model from name
@@ -51,6 +99,9 @@ internal class SettingsUtils {
